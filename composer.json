{
    "name": "cwsaus/cwsaus",
    "description": "CWS Australia - CakePHP 4",
    "homepage": "https://github.com/cwsaus/cwsaus",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "cakephp/cakephp": "^4.4",
        "cakephp/migrations": "^3.2",
        "cakephp/plugin-installer": "^1.3",
        "josegonzalez/dotenv": "^3.2",
        "stripe/stripe-php": "^9.0|^10.0"
    },
    "require-dev": {
        "cakephp/bake": "^2.9",
        "cakephp/cakephp-codesniffer": "^4.6",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/"
        }
    },
    "scripts": {
    },
    "config": {
        "allow-plugins": {
            "cakephp/plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "prefer-stable": true,
    "minimum-stability": "dev"
}
