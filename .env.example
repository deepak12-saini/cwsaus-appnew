# Copy to .env on each server (never commit .env)

APP_ENCODING=UTF-8
APP_DEFAULT_LOCALE=en_US
APP_DEFAULT_TIMEZONE=Australia/Sydney
DEBUG=false
SECURITY_SALT=change-this-to-a-long-random-string

DB_HOST=localhost
# DB_PORT=3307
# Omit DB_PORT on production (default 3306). Use 3307 only for local XAMPP if configured.

DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

APP_BASE=/
# Local XAMPP subfolder: APP_BASE=/ (bootstrap auto-detects /cwsaus)
# Production: APP_BASE=/ and FULL_BASE_URL=https://cwsaus.com.au

FULL_BASE_URL=https://cwsaus.com.au
# Local: FULL_BASE_URL=http://localhost

EMAIL_HOST=mail.cwsaus.com.au
EMAIL_PORT=587
EMAIL_USERNAME=info@cwsaus.com.au
EMAIL_PASSWORD=your_smtp_password
EMAIL_TLS=true
